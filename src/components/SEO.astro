---
interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  lang?: 'en';
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
  categoryPath?: string;
}

const {
  title,
  description = 'Open-source, AI-friendly knowledge base about Russia.',
  image = '/favicon.png',
  url = Astro.url.href,
  lang = 'en',
  type = 'website',
  datePublished,
  dateModified,
  content,
  tags,
  category,
  categoryPath,
} = Astro.props;

const fullTitle = `${title} | Russia.md`;
const siteUrl = 'https://russia-md.ru';
const fullImageUrl = new URL(image, siteUrl).href;

// Generate AI-friendly summary from description or content
const aiSummary =
  description ||
  (content
    ? content
        .substring(0, 200)
        .replace(/[\n\r]/g, ' ')
        .replace(/[#*]/g, '')
        .trim() + '...'
    : '');

// Generate JSON-LD structured data
const generateJSONLD = () => {
  if (categoryPath === 'people') {
    return {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: title,
      description: description,
      url: url,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
    };
  }

  if (type === 'article' && datePublished) {
    return {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description: description,
      author: {
        '@type': 'Organization',
        name: 'Russia.md',
        url: siteUrl,
      },
      publisher: {
        '@type': 'Organization',
        name: 'Russia.md',
        url: siteUrl,
        logo: {
          '@type': 'ImageObject',
          url: `${siteUrl}/favicon.png`,
          width: 512,
          height: 512,
        },
      },
      datePublished: datePublished,
      dateModified: dateModified || datePublished,
      inLanguage: lang,
      url: url,
      image: {
        '@type': 'ImageObject',
        url: fullImageUrl,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
      ...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
      ...(category ? { articleSection: category } : {}),
    };
  } else {
    return {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Russia.md',
      description: 'Open-source, AI-friendly knowledge base about Russia',
      url: siteUrl,
      inLanguage: lang,
      publisher: {
        '@type': 'Organization',
        name: 'Russia.md',
        url: siteUrl,
      },
    };
  }
};

const jsonLD = generateJSONLD();

const organizationLD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Russia.md',
  url: siteUrl,
  logo: `${siteUrl}/favicon.png`,
  description: 'Open-source, AI-friendly knowledge base about Russia.',
  sameAs: [
    'https://github.com/denis-gordeev/russia-md',
    'https://github.com/frank890417/taiwan-md',
  ],
};

// Dynamic keywords
const baseKeywords =
  'Russia, Russian history, Russian culture, Russian economy, Russian geography';
const dynamicKeywords = [
  baseKeywords,
  ...(category ? [category] : []),
  ...(tags && tags.length > 0 ? tags : []),
].join(', ');

const pathParts = new URL(url).pathname.split('/').filter(Boolean);
const resolvedCategoryPath = categoryPath || pathParts[0] || null;
const breadcrumbLD =
  pathParts.length === 0
    ? null
    : {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: 'Russia.md',
            item: siteUrl,
          },
          ...(resolvedCategoryPath && pathParts.length >= 1
            ? [
                {
                  '@type': 'ListItem',
                  position: 2,
                  name: category || resolvedCategoryPath,
                  item: `${siteUrl}/${resolvedCategoryPath}`,
                },
              ]
            : []),
          ...(type === 'article' && pathParts.length >= 2
            ? [
                {
                  '@type': 'ListItem',
                  position: resolvedCategoryPath ? 3 : 2,
                  name: title,
                  item: url,
                },
              ]
            : pathParts.length === 1
              ? []
              : [
                  {
                    '@type': 'ListItem',
                    position: resolvedCategoryPath ? 3 : 2,
                    name: title,
                    item: url,
                  },
                ]),
        ],
      };
---

<!-- Basic Meta Tags -->
<meta name="description" content={description} />
<meta name="keywords" content={dynamicKeywords} />
<meta name="author" content="Russia.md" />
<meta name="generator" content="Russia.md" />

<!-- AI-friendly summary meta tag -->
<meta name="ai-summary" content={aiSummary} />

<!-- Canonical URL -->
<link rel="canonical" href={url} />

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title="Russia.md RSS Feed"
  href={`${siteUrl}/feed.xml`}
/>

<!-- Language Tags -->
<link rel="alternate" hreflang="en" href={siteUrl} />
<link rel="alternate" hreflang="x-default" href={siteUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:alt" content={`${title} - Russia.md`} />
<meta property="og:site_name" content="Russia.md" />
<meta property="og:locale" content="en_US" />
{
  datePublished && (
    <meta property="article:published_time" content={datePublished} />
  )
}
{
  dateModified && (
    <meta property="article:modified_time" content={dateModified} />
  )
}
{
  tags &&
    tags.map((tag: string) => <meta property="article:tag" content={tag} />)
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={`${title} - Russia.md`} />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLD, null, 2)} />
<script
  type="application/ld+json"
  set:html={JSON.stringify(organizationLD, null, 2)}
/>
{
  breadcrumbLD && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbLD, null, 2)}
    />
  )
}
