{
  "type": "object",
  "required": ["name", "interface", "policy"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "interface": {
      "type": "object",
      "required": [
        "display_name",
        "short_description",
        "brand_color",
        "default_prompt"
      ],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "short_description": { "type": "string", "minLength": 1 },
        "brand_color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "default_prompt": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["allow_implicit_invocation"],
      "properties": {
        "allow_implicit_invocation": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
