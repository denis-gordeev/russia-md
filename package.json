{
  "name": "russia-md",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "test:content": "node scripts/test-frontmatter.mjs",
    "test:content:ci": "node scripts/test-frontmatter.mjs --ci",
    "test:content:staged": "node scripts/test-frontmatter.mjs --staged",
    "postbuild": "node scripts/post-build-check.mjs",
    "preview": "astro preview",
    "check:hollow": "bash tools/detect-ai-hollow.sh",
    "check:hollow:diff": "bash tools/detect-ai-hollow.sh --diff --sort",
    "check-links": "bash scripts/check-links.sh",
    "check:skills": "node scripts/validate-skill-examples.mjs",
    "check:skills:changed": "node scripts/validate-skill-examples.mjs --changed",
    "check:skills:staged": "node scripts/validate-skill-examples.mjs --staged",
    "check:skills:fixtures": "node scripts/test-validate-skill-examples.mjs",
    "sync": "bash scripts/sync.sh",
    "sync:build": "bash scripts/sync.sh && astro build",
    "check-images": "node scripts/check-images.mjs",
    "astro": "astro",
    "format::check": "prettier --check .",
    "format::write": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "astro": "^6.0.5",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "rehype-external-links": "^3.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1"
  }
}
